            <div class="text-center">
                <h2 class="text-3xl font-black text-slate-800 mb-2">What would you like to learn?</h2>
                <p class="text-slate-500 font-medium">Pick a language path to start your interactive test.</p>
            </div>
            
            <div class="grid grid-cols-1 gap-4 mt-6">
                <button onclick="startLesson('html')" class="flex items-center p-5 bg-white border-2 border-slate-200 rounded-2xl hover:border-orange-400 hover:bg-orange-50 text-left font-bold transition-all cursor-pointer group">
                    <span class="text-4xl mr-4 group-hover:scale-110 transition-transform">🌐</span>
                    <div>
                        <h3 class="text-lg text-slate-800">HTML Web Structures</h3>
                        <p class="text-sm text-slate-400 font-medium">Learn headings, paragraphs, and tags.</p>
                    </div>
                </button>

                <button onclick="startLesson('python')" class="flex items-center p-5 bg-white border-2 border-slate-200 rounded-2xl hover:border-blue-400 hover:bg-blue-50 text-left font-bold transition-all cursor-pointer group">
                    <span class="text-4xl mr-4 group-hover:scale-110 transition-transform">🐍</span>
                    <div>
                        <h3 class="text-lg text-slate-800">Python Logic</h3>
                        <p class="text-sm text-slate-400 font-medium">Learn variables, loops, and syntax.</p>
                    </div>
                </button>

