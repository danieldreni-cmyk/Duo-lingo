<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GitLingo - Learn Coding</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .block-btn { transition: all 0.2s ease; }
        .block-btn:active { transform: scale(0.95); }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-800 min-h-screen flex flex-col justify-between">

    <header class="border-b border-slate-200 bg-white p-4 sticky top-0 z-10">
        <div class="max-w-2xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-black text-emerald-500 tracking-wide cursor-pointer" onclick="showLanguageSelection()">gitlingo</h1>
            <div class="flex items-center space-x-4 font-bold text-slate-600">
                <span id="streak-display">🔥 1 Day Streak</span>
                <span id="score-display" class="text-amber-500">⭐ XP: 0</span>
            </div>
        </div>
    </header>

    <main class="max-w-2xl w-full mx-auto p-4 flex-grow flex flex-col justify-center">
        
